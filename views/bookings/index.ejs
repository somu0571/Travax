<% layout("/layouts/boilerplate") %>

    <div class="container mt-5 mb-5">
        <h2 class="mb-4">My Bookings</h2>

        <% if (myBookings.length===0) { %>
            <div class="text-center py-5">
                <i class="fa-solid fa-suitcase-rolling mb-3" style="font-size: 3rem; color: #ced4da;"></i>
                <p class="text-muted">You haven't made any bookings yet.</p>
                <a href="/listings" class="btn btn-outline-dark mt-2">Explore Stays</a>
            </div>
            <% } else { %>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <% for(let booking of myBookings) { %>
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 rounded-4">
                                <div class="card-body">
                                    <h5 class="card-title fw-bold text-truncate">
                                        <%= booking.listing.title %>
                                    </h5>
                                    <p class="text-muted small mb-3">
                                        <%= booking.startDate.toDateString() %> to <%= booking.endDate.toDateString() %>
                                    </p>

                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small">Total Paid:</span>
                                        <span class="fw-bold">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                    </div>

                                    <div class="d-flex justify-content-between mb-3">
                                        <span class="text-muted small">Guests:</span>
                                        <span class="small">
                                            <%= booking.adults %> Adults, <%= booking.children %> Children
                                        </span>
                                    </div>
                                </div>

                                <div class="card-footer bg-white border-0 pb-3 px-3">
                                    <a href="/listings/<%= booking.listing._id %>"
                                        class="btn btn-sm btn-outline-dark w-100 mb-2 rounded-3">View Property</a>

                                    <% if (booking.startDate> new Date()) { %>
                                        <button type="button" class="btn btn-sm btn-outline-danger w-100 rounded-3"
                                            data-bs-toggle="modal" data-bs-target="#cancelModal<%= booking._id %>">
                                            Cancel Booking
                                        </button>
                                        <% } else { %>
                                            <button class="btn btn-sm btn-outline-secondary w-100 rounded-3"
                                                disabled>Past Booking</button>
                                            <% } %>
                                </div>
                            </div>
                        </div>

                        <% if (booking.startDate> new Date()) { %>
                            <div class="modal fade" id="cancelModal<%= booking._id %>" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <form
                                        action="/listings/<%= booking.listing._id %>/bookings/<%= booking._id %>?_method=DELETE"
                                        method="POST">
                                        <div class="modal-content">
                                            <div class="modal-body px-4 pt-3">
                                                <p class="text-muted small mb-3">Please select a reason to help us
                                                    improve our stays:</p>

                                                <div class="d-flex flex-column gap-2">
                                                    <input type="radio" class="btn-check" name="reason"
                                                        id="reason1<%= booking._id %>" value="Changed plans" required>
                                                    <label
                                                        class="btn btn-outline-dark text-start py-3 px-3 rounded-3 d-flex align-items-center"
                                                        for="reason1<%= booking._id %>">
                                                        <i class="fa-solid fa-calendar-xmark me-3 text-muted fs-5"></i>
                                                        <span class="fw-medium">Changed plans</span>
                                                    </label>

                                                    <input type="radio" class="btn-check" name="reason"
                                                        id="reason2<%= booking._id %>" value="Found better price">
                                                    <label
                                                        class="btn btn-outline-dark text-start py-3 px-3 rounded-3 d-flex align-items-center"
                                                        for="reason2<%= booking._id %>">
                                                        <i class="fa-solid fa-tags me-3 text-muted fs-5"></i>
                                                        <span class="fw-medium">Found better price</span>
                                                    </label>

                                                    <input type="radio" class="btn-check" name="reason"
                                                        id="reason3<%= booking._id %>" value="Host unresponsive">
                                                    <label
                                                        class="btn btn-outline-dark text-start py-3 px-3 rounded-3 d-flex align-items-center"
                                                        for="reason3<%= booking._id %>">
                                                        <i class="fa-solid fa-comment-slash me-3 text-muted fs-5"></i>
                                                        <span class="fw-medium">Host unresponsive</span>
                                                    </label>

                                                    <input type="radio" class="btn-check" name="reason"
                                                        id="reason4<%= booking._id %>" value="Other">
                                                    <label
                                                        class="btn btn-outline-dark text-start py-3 px-3 rounded-3 d-flex align-items-center"
                                                        for="reason4<%= booking._id %>">
                                                        <i class="fa-solid fa-ellipsis me-3 text-muted fs-5"></i>
                                                        <span class="fw-medium">Other</span>
                                                    </label>
                                                </div>
                                            </div>

                                            <div class="modal-footer border-0 px-4 pb-4 pt-2 d-flex gap-2">
                                                <button type="button"
                                                    class="btn btn-light text-muted flex-grow-1 py-2.5 rounded-3 fw-medium"
                                                    data-bs-dismiss="modal">Keep Booking</button>
                                                <button type="submit"
                                                    class="btn btn-danger flex-grow-1 py-2.5 rounded-3 fw-medium shadow-sm">Cancel
                                                    Booking</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <% } %>
                                <% } %>
                </div>
                <% } %>
    </div>