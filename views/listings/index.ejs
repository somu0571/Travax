<% layout("/layouts/boilerplate") %>

  <body>
    <div class="filters">

      <a href="/listings?category=Trending" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-fire"></i>
          <p>Trending</p>
        </div>
      </a>

      <a href="/listings?category=Beachfront" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-umbrella-beach"></i>
          <p>Beachfront</p>
        </div>
      </a>

      <a href="/listings?category=Pools" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-person-swimming"></i>
          <p>Amazing Pools</p>
        </div>
      </a>

      <a href="/listings?category=Mountains" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-mountain"></i>
          <p>Mountains</p>
        </div>
      </a>

      <a href="/listings?category=City" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-city"></i>
          <p>Iconic Cities</p>
        </div>
      </a>

      <a href="/listings?category=Camping" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-campground"></i>
          <p>Camping</p>
        </div>
      </a>

      <a href="/listings?category=Farms" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-tractor"></i>
          <p>Farms</p>
        </div>
      </a>


      <a href="/listings?category=Arctic" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-snowflake"></i>
          <p>Arctic</p>
        </div>
      </a>

      <a href="/listings?category=Houseboats" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-sailboat"></i>
          <p>Houseboats</p>
        </div>
      </a>

      <a href="/listings?category=Castles" class="filter-link">
        <div class="filter">
          <i class="fa-brands fa-fort-awesome"></i>
          <p>Castles</p>
        </div>
      </a>

      <a href="/listings?category=Luxury" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-gem"></i>
          <p>Luxe</p>
        </div>
      </a>

      <a href="/listings?category=Breakfast" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-mug-hot"></i>
          <p>B&Bs</p>
        </div>
      </a>

      <a href="/listings?category=Vineyards" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-wine-glass"></i>
          <p>Vineyards</p>
        </div>
      </a>

      <a href="/listings?category=Golfing" class="filter-link">
        <div class="filter">
          <i class="fa-solid fa-golf-ball-tee"></i>
          <p>Golfing</p>
        </div>
      </a>

    </div>
    <% if (allListings.length===0) { %>
      <div class="text-center my-5 py-5">
        <i class="fa-solid fa-folder-open text-muted mb-3" style="font-size: 3rem; opacity: 0.5;"></i>
        <h3 class="h5">No listings found in this category</h3>
        <p class="text-muted">Be the first to create a listing for this category!</p>
        <a href="/listings" class="btn btn-dark btn-sm mt-2">Back to All Listings</a>
      </div>
      <% } else { %>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-1">
          <% for(let listing of allListings) { %>
            <div class="col">
              <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none text-dark">
                <div class="card h-100 border-0 listing-card">

                  <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"
                    style="height: 20rem; object-fit: cover;">

                  <div class="card-img-overlay"></div>

                  <div class="card-body px-0 py-2">
                    <p class="card-text">
                      <b>
                        <%= listing.title %>
                      </b><br>
                      &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                        <br>
                        <span class="text-muted">
                          <%= listing.location %>, <%= listing.country %>
                        </span>
                    </p>
                  </div>
                </div>
              </a>
            </div>
            <% } %>
        </div>
        <% } %>
  </body>