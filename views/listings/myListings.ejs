<% layout("/layouts/boilerplate") %>

    <body>
        <h3 class="mt-3">My Listings</h3>

        <% if(allListings.length===0) { %>
            <div class="container text-center mt-5">
                <i class="fa-solid fa-house-user fa-3x" style="color: #cbd5e0;"></i>
                <p class="mt-3">You haven't created any listings yet.</p>
                <a href="/listings/new" class="btn btn-outline-dark">Create New Listing</a>
            </div>
            <% } else { %>
                <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
                    <% for(let listing of allListings) { %>
                        <div class="card col listing-card">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"
                                style="height: 20rem;">
                            <div class="card-body">
                                <p class="card-text"><b>
                                        <%= listing.title %>
                                    </b></p>
                                <a href="/listings/<%= listing._id %>" class="btn btn-primary">View Listing</a>
                            </div>
                        </div>
                        <% } %>
                </div>
                <% } %>
    </body>